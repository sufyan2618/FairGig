SERVICE_NAME=certificate-renderer-service
SERVICE_VERSION=1.0.0
API_PREFIX=/api/certificate
PORT=8004

# Keep this aligned with authService ACCESS_TOKEN_SECRET
JWT_SECRET=change-access-token-secret
ACCESS_TOKEN_SECRET=change-access-token-secret
JWT_ALGORITHM=HS256

EARNINGS_SERVICE_URL=http://localhost:3001/api/earnings
INTERNAL_SERVICE_API_KEY=fairgig-internal-dev-key
REQUEST_TIMEOUT_SECONDS=8

TEMPLATE_DIR=app/templates
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
