SERVICE_NAME=analytics-service
SERVICE_VERSION=1.0.0
API_PREFIX=/api/analytics
PORT=8003

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fairgig_analytics
EARNINGS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fairgig_earnings

# Keep this aligned with authService ACCESS_TOKEN_SECRET
JWT_SECRET=change-access-token-secret
ACCESS_TOKEN_SECRET=change-access-token-secret
JWT_ALGORITHM=HS256

CACHE_TTL_SECONDS=900
PLATFORMS_CACHE_TTL_SECONDS=1800
GRIEVANCE_CACHE_TTL_SECONDS=300
MIN_COHORT_SIZE=5
WORKER_REF_SALT=fairgig-worker-ref-salt

GRIEVANCE_SERVICE_URL=http://localhost:3002/api/grievances
GRIEVANCE_TIMEOUT_SECONDS=5

CORS_ORIGINS=http://localhost:5173,http://localhost:8080
