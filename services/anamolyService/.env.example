PORT=8002
API_PREFIX=/api/anomaly
SERVICE_NAME=anomaly-detection
SERVICE_VERSION=1.0.0

# Keep this aligned with authService ACCESS_TOKEN_SECRET
ACCESS_TOKEN_SECRET=change-access-token-secret
JWT_ALGORITHM=HS256

# Active AI provider settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20

# Internal caller key for backend-to-backend requests
INTERNAL_SERVICE_API_KEY=fairgig-internal-dev-key

# Set true only for demo mode if /detect should be callable without auth
ALLOW_OPEN_DETECT=false

ALLOWED_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
