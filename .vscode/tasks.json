      "label": "FairGig Dev: Stop API Gateway",
      "type": "shell",
      "command": "$gatewayPid = Get-NetTCPConnection -LocalPort 8080 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 1 -ExpandProperty OwningProcess; if ($gatewayPid) { Stop-Process -Id $gatewayPid -Force; Write-Output \"Stopped gateway process $gatewayPid\" } else { Write-Output \"No API gateway process listening on port 8080\" }",
