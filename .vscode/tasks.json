{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FairGig Dev: Auth Service",
      "type": "shell",
      "command": "Set-Location \"${workspaceFolder}/services/authService\"; & \"${workspaceFolder}/services/authService/.venv/Scripts/python.exe\" -m alembic upgrade head; & \"${workspaceFolder}/services/authService/.venv/Scripts/python.exe\" -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "clear": false
